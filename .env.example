# =============================================================================
# Glassbox AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# Required
GLASSBOX_SECRET_KEY=change-me-to-a-random-32-char-string

# Optional — logging
GLASSBOX_LOG_LEVEL=info

# Optional — worker count (Railway/Fly: 1, bare metal: match CPU cores)
GLASSBOX_MAX_WORKERS=2

# Optional — set to 1 in air-gapped VPC (disables HuggingFace Hub downloads)
HF_HUB_OFFLINE=0

# Optional — path on host machine for model weight cache (docker-compose)
MODEL_CACHE_PATH=./data/model_cache

# Optional — MLflow experiment tracking
# MLFLOW_TRACKING_URI=http://localhost:5000

# Optional — Slack compliance alerting
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Optional — Microsoft Teams compliance alerting
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# Optional — PyPI publish token (used by GitHub Actions only)
# PYPI_API_TOKEN=pypi-xxx

# Optional — HuggingFace Hub token (used by GitHub Actions only)
# HF_TOKEN=hf_xxx
